# J1939 transport.c coverage test case
# Covers TP (Transport Protocol) and ETP (Extended Transport Protocol)
# Optimized to stay within 40 syscall limit

# Create two J1939 sockets for TP testing
r0 = socket$can_j1939(0x1d, 0x2, 0x7)
ioctl$ifreq_SIOCGIFINDEX_vcan(r0, 0x8933, &AUTO={'vcan0\x00', <r1=>0x0})
bind$can_j1939(r0, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x11}, 0x18)

r2 = socket$can_j1939(0x1d, 0x2, 0x7)
bind$can_j1939(r2, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x22}, 0x18)

# Test 1: Basic TP (Transport Protocol) - triggers TP.CM and TP.DT
connect$can_j1939(r2, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x11}, 0x18)
sendmsg$can_j1939(r2, &AUTO={&AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x11}, 0x18, &AUTO={&AUTO="0102030405060708091011121314151617181920", 0x28}, 0x1, 0x0, 0x0, 0x0}, 0x0)
recvmsg$can_j1939(r0, &AUTO={0x0, 0x0, &AUTO={&AUTO=""/64, 0x40}, 0x1, 0x0, 0x0, 0x0}, 0x0)

# Test 2: Medium TP message (256-1785 bytes)
sendmsg$can_j1939(r2, &AUTO={&AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x11}, 0x18, &AUTO={&AUTO=""/512, 0x200}, 0x1, 0x0, 0x0, 0x0}, 0x0)
recvmsg$can_j1939(r0, &AUTO={0x0, 0x0, &AUTO={&AUTO=""/512, 0x200}, 0x1, 0x0, 0x0, 0x0}, 0x0)

# Test 3: ETP (Extended Transport Protocol) - Messages >1785 bytes
connect$can_j1939(r2, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x33}, 0x18)
sendmsg$can_j1939(r2, &AUTO={&AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x33}, 0x18, &AUTO={&AUTO=""/2048, 0x800}, 0x1, 0x0, 0x0, 0x0}, 0x0)
recvmsg$can_j1939(r0, &AUTO={0x0, 0x0, &AUTO={&AUTO=""/2048, 0x800}, 0x1, 0x0, 0x0, 0x0}, 0x0)

# Test 4: Broadcast Transport Protocol (BAM)
sendmsg$can_j1939(r2, &AUTO={&AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0xff}, 0x18, &AUTO={&AUTO="0102030405060708091011121314151617181920212223", 0x30}, 0x1, 0x0, 0x0, 0x0}, 0x0)

# Test 5: Socket options for transport protocol
setsockopt$SO_J1939_PROMISC(r0, 0x6a, 0x1, &AUTO=0x1, 0x4)
setsockopt$SO_J1939_ERRQUEUE(r0, 0x6a, 0x3, &AUTO=0x1, 0x4)
setsockopt$SO_J1939_SEND_PRIO(r0, 0x6a, 0x4, &AUTO=0x3, 0x4)

getsockopt$SO_J1939_PROMISC(r0, 0x6a, 0x1, &AUTO=0x0, &AUTO=0x4)
getsockname$can_j1939(r0, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x11}, 0x18)
getpeername$can_j1939(r2, &AUTO={0x1d, r1, 0x0, {0x0, 0x0, 0x0, 0x0}, 0x22}, 0x18)

# Cleanup
close(r0)
close(r2)